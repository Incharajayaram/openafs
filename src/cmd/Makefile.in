srcdir=@srcdir@
include @TOP_OBJDIR@/src/config/Makefile.config
include @TOP_OBJDIR@/src/config/Makefile.pthread
include @TOP_OBJDIR@/src/config/Makefile.libtool

LT_objs=cmd_errors.lo cmd.lo config_file.lo AFS_component_version_number.lo
LT_deps=$(top_builddir)/src/comerr/liboafs_comerr.la
LT_libs=

COMPLETION_TOOLS=$(TOP_OBJDIR)/src/bozo/bos \
	$(TOP_OBJDIR)/src/ptserver/pts \
	$(TOP_OBJDIR)/src/ubik/udebug \
	$(TOP_OBJDIR)/src/venus/fs \
	$(TOP_OBJDIR)/src/volser/vos
COMPLETION_KAS=$(TOP_OBJDIR)/src/kauth/kas
COMPLETION_BASH_DIR=$(srcdir)/completions/bash
COMPLETION_ZSH_DIR=$(srcdir)/completions/zsh
COMPLETION_ENV=LD_LIBRARY_PATH="$(TOP_OBJDIR)/lib$${LD_LIBRARY_PATH:+:$$LD_LIBRARY_PATH}" \
	DYLD_LIBRARY_PATH="$(TOP_OBJDIR)/lib$${DYLD_LIBRARY_PATH:+:$$DYLD_LIBRARY_PATH}" \
	SHLIB_PATH="$(TOP_OBJDIR)/lib$${SHLIB_PATH:+:$$SHLIB_PATH}" \
	LIBPATH="$(TOP_OBJDIR)/lib$${LIBPATH:+:$$LIBPATH}"

LIB64OBJS=cmd_errors64.o cmd64.o

all: ${TOP_LIBDIR}/libcmd.a ${TOP_LIBDIR}/libcmd_pic.a \
     ${TOP_INCDIR}/afs/cmd.h liboafs_cmd.la

all64: all ${TOP_LIBDIR}/libcmd64.a

generated: cmd.h cmd_errors.c

completions: $(srcdir)/generate_completions.pl
	$(MAKE) -C $(TOP_OBJDIR) $(COMPLETION_TOOLS) $(COMPLETION_KAS)
	$(COMPLETION_ENV) $(PERL) $(srcdir)/generate_completions.pl \
		--format bash --out-dir $(COMPLETION_BASH_DIR) \
		$(COMPLETION_TOOLS)
	$(COMPLETION_ENV) $(PERL) $(srcdir)/generate_completions.pl \
		--format bash --out-dir $(COMPLETION_BASH_DIR) --afsconf-temp \
		$(COMPLETION_KAS)
	$(COMPLETION_ENV) $(PERL) $(srcdir)/generate_completions.pl \
		--format zsh --out-dir $(COMPLETION_ZSH_DIR) \
		$(COMPLETION_TOOLS)
	$(COMPLETION_ENV) $(PERL) $(srcdir)/generate_completions.pl \
		--format zsh --out-dir $(COMPLETION_ZSH_DIR) --afsconf-temp \
		$(COMPLETION_KAS)

${TOP_LIBDIR}/libcmd.a: libcmd.a
	${INSTALL_DATA} $? $@

${TOP_LIBDIR}/libcmd_pic.a: libcmd_pic.la
	$(INSTALL_DATA) .libs/libcmd_pic.a $@

${TOP_LIBDIR}/libcmd64.a: libcmd64.a
	${INSTALL_DATA} $? $@

${TOP_INCDIR}/afs/cmd.h: cmd.h
	${INSTALL_DATA} $? $@

cmd_errors.c: cmd_errors.et
	${COMPILE_ET_C} -p ${srcdir} cmd_errors

cmd.h: cmd_errors.et cmd.p.h
	${COMPILE_ET_H} -p ${srcdir} cmd_errors -h cmd

cmd.lo: cmd.h
config_file.lo: cmd.h

config_file.lo: $(TOP_SRCDIR)/external/heimdal/krb5/config_file.c krb5_locl.h
	$(LT_CCRULE) $(TOP_SRCDIR)/external/heimdal/krb5/config_file.c

cmd_errors64.o: cmd_errors.c
	${CC} $(COMMON_CFLAGS) $(CPPFLAGS) ${XCFLAGS64} \
		-c -o cmd_errors64.o cmd_errors.c

cmd64.o: cmd.c cmd.h
	${CC} $(COMMON_CFLAGS) $(CPPFLAGS) ${XCFLAGS64} \
		-c -o cmd64.o ${srcdir}/cmd.c

libcmd64.a: ${LIB64OBJS} AFS_component_version_number64.o
	-$(RM) -f $@
	$(AR) $(ARFLAGS) $@ ${LIB64OBJS} AFS_component_version_number64.o
	$(RANLIB) $@

libcmd.a: $(LT_objs)
	$(LT_LDLIB_static) $(LT_objs)

libcmd_pic.la: $(LT_objs)
	$(LT_LDLIB_pic) $(LT_objs)

liboafs_cmd.la: $(LT_objs) $(LT_deps)
	$(LT_LDLIB_shlib) $(LT_objs) $(LT_deps) $(LT_libs)

AFS_component_version_number64.o: AFS_component_version_number.c
	${CC} $(COMMON_CFLAGS) $(CPPFLAGS) ${XCFLAGS64} \
		-c -o AFS_component_version_number64.o \
		AFS_component_version_number.c

#
# Install targets
#
install: libcmd.a cmd.h completions
	${INSTALL} -d ${DESTDIR}${libdir}/afs
	${INSTALL} -d ${DESTDIR}${includedir}/afs
	${INSTALL_DATA} libcmd.a ${DESTDIR}$(libdir)/afs/libcmd.a
	${INSTALL_DATA} cmd.h ${DESTDIR}${includedir}/afs/cmd.h
	${INSTALL} -d ${DESTDIR}${datadir}/bash-completion/completions
	for f in $(srcdir)/completions/bash/*.bash; do \
		base=`basename "$$f" .bash`; \
		${INSTALL_DATA} "$$f" ${DESTDIR}${datadir}/bash-completion/completions/$$base; \
	done
	${INSTALL} -d ${DESTDIR}${datadir}/zsh/site-functions
	${INSTALL_DATA} $(srcdir)/completions/zsh/_* ${DESTDIR}${datadir}/zsh/site-functions/

install64: install libcmd64.a
	${INSTALL_DATA} libcmd64.a ${DESTDIR}${libdir}/afs/libcmd64.a

dest: libcmd.a cmd.h completions
	${INSTALL} -d ${DEST}/lib/afs
	${INSTALL} -d ${DEST}/include/afs
	${INSTALL_DATA} libcmd.a ${DEST}/lib/afs/libcmd.a
	${INSTALL_DATA} cmd.h ${DEST}/include/afs/cmd.h
	${INSTALL} -d ${DEST}/share/bash-completion/completions
	for f in $(srcdir)/completions/bash/*.bash; do \
		base=`basename "$$f" .bash`; \
		${INSTALL_DATA} "$$f" ${DEST}/share/bash-completion/completions/$$base; \
	done
	${INSTALL} -d ${DEST}/share/zsh/site-functions
	${INSTALL_DATA} $(srcdir)/completions/zsh/_* ${DEST}/share/zsh/site-functions/

dest64: dest libcmd64.a
	${INSTALL_DATA} libcmd64.a ${DEST}/lib/afs/libcmd64.a

#
# Misc targets
#
test tests:
	(cd test; $(MAKE) )

clean:
	$(LT_CLEAN)
	$(RM) -f  *.a *.o ctest dtest cmd.h cmd_errors.c core \
		  AFS_component_version_number.c

include ../config/Makefile.version
